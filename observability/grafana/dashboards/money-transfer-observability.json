{
  "uid": "money-transfer-observability",
  "title": "Money Transfer Observability",
  "tags": [
    "money-transfer",
    "opentelemetry",
    "local"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(job)",
        "query": {
          "query": "label_values(job)",
          "refId": "PrometheusVariableQuery"
        },
        "regex": "",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "route",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(http_route)",
        "query": {
          "query": "label_values(http_route)",
          "refId": "PrometheusVariableQuery"
        },
        "regex": "",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "status",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(http_response_status_code)",
        "query": {
          "query": "label_values(http_response_status_code)",
          "refId": "PrometheusVariableQuery"
        },
        "regex": "",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "title": "HTTP Overview",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "Total HTTP Requests",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(http_server_request_duration_seconds_count{job=~\"${service:raw}\", http_route=~\"${route:regex}\", http_response_status_code=~\"${status:regex}\"}[$__range])))",
          "legendFormat": "Total Requests",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "options": {
        "graphMode": "area"
      }
    },
    {
      "id": 12,
      "title": "HTTP Success Rate",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(increase(http_server_request_duration_seconds_count{job=~\"${service:raw}\", http_route=~\"${route:regex}\", http_response_status_code!~\"5..\"}[$__range])) / sum(increase(http_server_request_duration_seconds_count{job=~\"${service:raw}\", http_route=~\"${route:regex}\"}[$__range]))",
          "legendFormat": "Success Rate",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "options": {
        "graphMode": "area"
      }
    },
    {
      "id": 13,
      "title": "Active Requests",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(http_server_active_requests{job=~\"${service:raw}\"})",
          "legendFormat": "Active Requests",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "options": {
        "graphMode": "area"
      }
    },
    {
      "id": 20,
      "title": "HTTP Metrics",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "title": "HTTP Request Rate by Route & Status",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_server_request_duration_seconds_count{job=~\"${service:raw}\", http_route=~\"${route:regex}\", http_response_status_code=~\"${status:regex}\"}[$__range])) by (http_route, http_response_status_code) / $__range_s",
          "legendFormat": "{{http_route}} ({{http_response_status_code}})",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 22,
      "title": "HTTP Latency (p50, p95, p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(increase(http_server_request_duration_seconds_bucket{job=~\"${service:raw}\", http_route=~\"${route:regex}\"}[$__range])) by (le, http_route))",
          "legendFormat": "{{http_route}} p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(increase(http_server_request_duration_seconds_bucket{job=~\"${service:raw}\", http_route=~\"${route:regex}\"}[$__range])) by (le, http_route))",
          "legendFormat": "{{http_route}} p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(increase(http_server_request_duration_seconds_bucket{job=~\"${service:raw}\", http_route=~\"${route:regex}\"}[$__range])) by (le, http_route))",
          "legendFormat": "{{http_route}} p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 30,
      "title": "Status Splits & Errors",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "title": "Client Conflicts (409) Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_server_request_duration_seconds_count{job=~\"${service:raw}\", http_route=~\"${route:regex}\", http_response_status_code=\"409\"}[$__range])) by (http_route) / $__range_s",
          "legendFormat": "{{http_route}} 409",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 32,
      "title": "Server Errors (5xx) Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 15
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_server_request_duration_seconds_count{job=~\"${service:raw}\", http_route=~\"${route:regex}\", http_response_status_code=~\"5..\"}[$__range])) by (http_route, http_response_status_code) / $__range_s",
          "legendFormat": "{{http_route}} {{http_response_status_code}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 33,
      "title": "HTTP Status Distribution",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 15
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_server_request_duration_seconds_count{job=~\"${service:raw}\", http_route=~\"${route:regex}\"}[$__range])) by (http_response_status_code)",
          "legendFormat": "{{http_response_status_code}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd"
      }
    },
    {
      "id": 40,
      "title": "Dependency & Health Checks",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "title": "Liveness Request Rate (/health/live)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 23
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_server_request_duration_seconds_count{job=~\"${service:raw}\", http_route=\"/health/live\"}[$__range])) / $__range_s",
          "legendFormat": "Liveness",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 42,
      "title": "Readiness Request Rate (/health/ready)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 23
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_server_request_duration_seconds_count{job=~\"${service:raw}\", http_route=\"/health/ready\"}[$__range])) / $__range_s",
          "legendFormat": "Readiness",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 43,
      "title": "Health Check Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"money-transfer-api\"} |= \"health\"",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 50,
      "title": "Application & System Logs",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 51,
      "title": "API System Logs (No Errors/Warnings)",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"money-transfer-api\"} | json | _l != \"Warning\" and _l != \"Error\" and _l != \"Fatal\"",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 52,
      "title": "Business Warnings Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 8,
        "y": 30
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"money-transfer-api\"} | json | _l = \"Warning\" | line_format \"{{.ExceptionType}} status={{.StatusCode}} method={{.RequestMethod}} path={{.RequestPath}} correlationId={{.CorrelationId}} traceId={{.TraceId}} requestId={{.RequestId}}\"",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 53,
      "title": "Server Errors & Fatal Exceptions Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 30
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"money-transfer-api\"} | json | _l = \"Error\" | line_format \"{{.ExceptionType}} status={{.StatusCode}} method={{.RequestMethod}} path={{.RequestPath}} correlationId={{.CorrelationId}} traceId={{.TraceId}} requestId={{.RequestId}}\"",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        },
        {
          "refId": "B",
          "expr": "{service_name=\"money-transfer-api\"} | json | _l = \"Fatal\" | line_format \"{{.ExceptionType}} status={{.StatusCode}} method={{.RequestMethod}} path={{.RequestPath}} correlationId={{.CorrelationId}} traceId={{.TraceId}} requestId={{.RequestId}}\"",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 60,
      "title": "Runtime Analytics (Dotnet Target)",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 61,
      "title": "Memory Working Set & GC Heap Size",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "refId": "A",
          "expr": "dotnet_process_memory_working_set_bytes{job=~\"${service:raw}\"}",
          "legendFormat": "Working Set",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "B",
          "expr": "dotnet_gc_last_collection_heap_size_bytes{job=~\"${service:raw}\"}",
          "legendFormat": "GC Heap Size",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 62,
      "title": "GC Collections Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 6,
        "y": 40
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(dotnet_gc_collections_total{job=~\"${service:raw}\"}[$__rate_interval])) by (gc_heap_generation)",
          "legendFormat": "{{gc_heap_generation}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops/s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 63,
      "title": "ThreadPool & Active Threads",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 40
      },
      "targets": [
        {
          "refId": "A",
          "expr": "dotnet_thread_pool_thread_count_total{job=~\"${service:raw}\"}",
          "legendFormat": "Active Threads",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "B",
          "expr": "dotnet_thread_pool_queue_length_total{job=~\"${service:raw}\"}",
          "legendFormat": "ThreadPool Queue",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "C",
          "expr": "rate(dotnet_thread_pool_work_item_count_total{job=~\"${service:raw}\"}[$__rate_interval])",
          "legendFormat": "Work Items Processed/s",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 64,
      "title": "App Exception Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 40
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(dotnet_exceptions_total{job=~\"${service:raw}\"}[$__rate_interval])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops/s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ]
}
